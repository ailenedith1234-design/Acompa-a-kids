  <script>
        lucide.createIcons();

        // Mood selector
        document.querySelectorAll('#mood-selector .emoji-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#mood-selector .emoji-btn').forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
                const labels = { tranquilo: '😊 Tranquilo', inseguro: '😐 Inseguro', preocupado: '😟 Preocupado' };
                document.getElementById('mood-label').textContent = labels[btn.dataset.mood];
            });
        });

        // FAQ accordion
        document.querySelectorAll('.faq-toggle').forEach(btn => {
            btn.addEventListener('click', () => {
                const answer = btn.nextElementSibling;
                const icon = btn.querySelector('[data-lucide]');
                answer.classList.toggle('open');
                icon.style.transform = answer.classList.contains('open') ? 'rotate(180deg)' : '';
            });
